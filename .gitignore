# Ignore everything by default
*

# ── Source code ──────────────────────────────────────────────
!server/
!server/**
!shared/
!shared/**
!script/
!script/**

# ── Database migrations (required at runtime) ────────────────
!migrations/
!migrations/**

# ── CI/CD ────────────────────────────────────────────────────
!.github/
!.github/**
!.github/workflows/
!.github/workflows/**

# ── Root config files ────────────────────────────────────────
!package.json
!package-lock.json
!tsconfig.json
!drizzle.config.ts

# ── Docker ───────────────────────────────────────────────────
!Dockerfile
!docker-compose.yml
!.dockerignore

# ── Environment template (no secrets) ────────────────────────
!.env.example

# ── This file ────────────────────────────────────────────────
!.gitignore

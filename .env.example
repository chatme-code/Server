DATABASE_URL=postgresql://user:password@host:5432/dbname
SESSION_SECRET=ganti_dengan_random_string_panjang
REDIS_URL=redis://redis:6379
NODE_ENV=production
# Set ke "true" HANYA jika server sudah pakai HTTPS (domain + SSL)
# Set ke "false" jika masih pakai HTTP / IP langsung
COOKIE_SECURE=false
# Wajib diisi: random string panjang untuk sign JWT token mobile
JWT_SECRET=ganti_dengan_random_string_lain
# ImageKit CDN — dapatkan dari https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
